# OpenAI API key used by the server-side consultant widget.
OPENAI_API_KEY=your_openai_api_key

# Optional domain for the consultant's web search. Search stays disabled when unset.
# Use a hostname only; a scheme is accepted and normalized, but paths and ports are rejected.
CONSULT_SEARCH_DOMAIN=lambda19.org

# Admin panel credentials. Use a unique password in every environment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Random secret used to sign admin JWTs. Use at least 32 characters.
# Example generator: openssl rand -base64 48
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters

# PostgreSQL connection used for customer leads. The server applies migrations at startup.
DATABASE_URL=postgresql://lambda19:replace_with_a_strong_password@localhost:5432/lambda19

# Maximum number of PostgreSQL connections (optional, defaults to 10).
DATABASE_POOL_MAX=10

# Enable only when the PostgreSQL provider requires a verified TLS connection.
DATABASE_SSL=false

# Pino log level. Production logs are emitted as structured JSON to stdout.
LOG_LEVEL=info

# HTTP port used by the Express server.
PORT=3000

# Optional: disable Vite HMR in development environments without file watching.
DISABLE_HMR=false
