# OpenAI API key used by the server-side consultant widget.
OPENAI_API_KEY=your_openai_api_key

# Admin panel credentials. Use a unique password in every environment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Random secret used to sign admin JWTs. Use at least 32 characters.
# Example generator: openssl rand -base64 48
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters

# HTTP port used by the Express server.
PORT=3000

# Optional: disable Vite HMR in development environments without file watching.
DISABLE_HMR=false
